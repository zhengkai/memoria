{{ define "feed" }}<?xml version="1.0" encoding="utf-8"?>
<feed xmlns="http://www.w3.org/2005/Atom" xml:lang="zh-CN">
	<title type="text">Soulogic 灵魂逻辑</title>
	<updated>{{ .TSUpdate | RFC3339 }}</updated>
	<subtitle>硬盘里埋藏着我的光荣与梦想，我要用键盘把他们挖出来</subtitle>
	<id>soulogic.com:default</id>
	<link rel="alternate" type="text/html" hreflang="zh" href="{{.Meta.SiteBaseLink}}"/>
	<link rel="self" type="application/atom+xml" href="https://soulogic.com/rss"/>
	<icon>{{.Meta.Favicon}}</icon>
	<rights>CC BY-SA 4.0, Zheng Kai</rights>

{{ range .Entry }}{{ template "entry" . }}{{ end }}
</feed>
{{ end }}

{{ define "entry" }}<entry>
	<title>{{ .Title | html }}</title>
	<link rel="alternate" type="text/html" href="{{ .ID | linkItemFull }}"/>
	<id>soulogic.com:item:{{ .ID }}</id>
	<updated>{{ or (.DB.GetTsContent) (.DB.GetTsCreate) | RFC3339 }}</updated>
	<published>{{ .DB.GetTsCreate | RFC3339 }}</published>
	{{ if .DBMeta.GetOriginal }}<author>
		<name>Zheng Kai</name>
		<uri>https://soulogic.com/</uri>
		<email>zhengkai@gmail.com</email>
	</author>
	<rights>CC BY-SA 4.0, Zheng Kai</rights>{{ else }}<author>
		<name>转载</name>
	</author>{{ end }}
	<content type="html">{{ .Content | rssEscape }}</content>
</entry>
{{ end }}
